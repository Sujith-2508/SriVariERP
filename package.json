{
  "name": "sri-vari-enterprises",
  "version": "1.0.0",
  "description": "Billing and Collections ERP System",
  "author": "Sri Vari Enterprises",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "export": "next build",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "ELECTRON_BUILD=1 next build && electron-builder",
    "build:win": "ELECTRON_BUILD=1 next build && electron-builder --win",
    "build:mac": "ELECTRON_BUILD=1 next build && electron-builder --mac",
    "build:all": "ELECTRON_BUILD=1 next build && electron-builder --win --mac"
  },
  "build": {
    "appId": "com.srivari.erp",
    "productName": "Sri Vari ERP",
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sri Vari ERP"
    },
    "mac": {
      "icon": "public/icon.png"
    },
    "linux": {
      "icon": "public/icon.png"
    },
    "files": [
      "out/**/*",
      "main.js",
      "preload.js",
      ".env.local",
      "public/icon.ico",
      "public/icon.png"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/whatsapp-web.js/**/*",
      "node_modules/puppeteer/**/*",
      "node_modules/puppeteer-core/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@supabase/supabase-js": "^2.93.3",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.1",
    "googleapis": "^171.4.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "next": "^15.1.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.4.1",
    "whatsapp-web.js": "^1.34.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}